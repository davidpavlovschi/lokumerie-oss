generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("MEMBER")
  apiKey        String?   @unique
  accounts      Account[]
  sessions      Session[]
  skills        Skill[]
  sources       Source[]
  koutis        Kouti[]
  createdAt     DateTime  @default(now())
  lastSeenNotificationsAt DateTime @default(now())
}

model Skill {
  id           String                         @id @default(cuid())
  name         String
  slug         String                         @unique
  flavor       String
  tags         String[]
  description  String?
  published    Boolean                        @default(false)
  installCount Int                            @default(0)
  embedding    Unsupported("vector(768)")?
  authorId     String
  author       User                           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions     SkillVersion[]
  koutis       KoutiSkill[]
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt

  @@index([authorId])
}

model SkillVersion {
  id        String   @id @default(cuid())
  version   Int
  content   String   @db.Text
  bundle    Json?
  changelog String?
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([skillId, version])
  @@index([skillId])
}

model Kouti {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  coverImage  String?
  visibility  String       @default("public")
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  skills      KoutiSkill[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([authorId])
}

model KoutiSkill {
  id       String @id @default(cuid())
  koutiId  String
  skillId  String
  position Int    @default(0)
  kouti    Kouti  @relation(fields: [koutiId], references: [id], onDelete: Cascade)
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([koutiId, skillId])
  @@index([koutiId])
  @@index([skillId])
}

model ContentLink {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String
  targetType String
  targetId   String
  linkType   String
  weight     Float    @default(1.0)
  createdAt  DateTime @default(now())

  @@unique([sourceType, sourceId, targetType, targetId, linkType])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
}

model Source {
  id          String   @id @default(cuid())
  title       String
  url         String?
  sourceType  String
  description String?
  ogImage     String?
  content     String?  @db.Text
  origin      String?
  tags        String[]
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
}
